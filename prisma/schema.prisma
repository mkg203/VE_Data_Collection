generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Question {
  id                 String         @id @default(uuid())
  imageId            String         @default("") // Manual ID linking variants of the same image
  variantTag         String         @default("") // Short string for human review (e.g., "normal", "blurred")
  type               String         // "DISTANCE", "ANGLE", "SIZE", "STABILITY", "FIT"
  is_boolean         Boolean        @default(false)
  text               String
  imageUrl           String
  unit               String?        // e.g., "cm", "degrees"
  actualAnswerNum    Float?         // For distance, angle, size
  actualAnswerBool   Boolean?       // For stability, fit
  timesAsked         Int            @default(0)

  responses          UserResponse[]
  aiResponses        AiResponse[]
}

model AiResponse {
  id                 String         @id @default(uuid())
  questionId         String
  model              String         // "openai", "gemini", "claude"
  answerNum          Float?
  answerBool         Boolean?

  question           Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, model])
}

model User {
  id                 String         @id @default(uuid()) // Anonymous UUID from cookie
  createdAt          DateTime       @default(now())

  responses          UserResponse[]
}

model UserResponse {
  id                 String         @id @default(uuid())
  userId             String
  questionId         String
  answerNum          Float?
  answerBool         Boolean?
  createdAt          DateTime       @default(now())

  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  question           Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId]) // A user can only answer a question once
}
